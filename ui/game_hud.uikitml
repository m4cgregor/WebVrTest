<style>
  /* El contenedor principal es transparente y abarca todo el ancho y alto del panel (4x2m) */
  .panel-container {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: transparent;
  }

  /* Las pantallas de inicio y fin (Welcome / Game Over) tienen fondo sólido y bordes */
  .card-screen {
    width: 25; /* 25% de 4.0m = 1.0m de ancho */
    align-items: center;
    padding: 3;
    display: flex;
    flex-direction: column;
    background-color: #0b0f19;
    border-color: #1f2937;
    border-width: 0.2;
    border-radius: 4;
  }

  .screen {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* El HUD se alinea arriba para quedar en la esquina superior */
  .hud-screen {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
  }

  .hidden {
    display: none;
  }

  .heading {
    font-size: 4.5;
    font-weight: bold;
    color: #3b82f6; /* Azul brillante */
    text-align: center;
    margin-bottom: 1;
  }

  .sub-heading {
    font-size: 2.2;
    color: #9ca3af;
    text-align: center;
    margin-top: 0.5;
    margin-bottom: 2;
  }

  /* El HUD del juego se divide en dos bloques a los extremos, dejando el centro libre */
  .hud-split-container {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    padding-left: 0;
    padding-right: 0;
  }

  /* Cada bloque individual del HUD (Score y Life) mide 0.3m x 0.3m (8% ancho, 15% alto del panel 4x2m) */
  .hud-card {
    width: 8%;
    height: 15%;
    background-color: #0b0f19;
    border-color: #1f2937;
    border-width: 0.15;
    border-radius: 3;
    align-items: center;
    justify-content: center;
  }

  /* Reducimos el tamaño de la fuente para que quepa perfectamente en los 0.3m de la tarjeta */
  .hud-item {
    font-size: 2.2;
    font-weight: bold;
    color: #f3f4f6;
    text-align: center;
  }

  .btn {
    width: 80%;
    padding: 1.5;
    background-color: #3b82f6;
    color: #ffffff;
    border-radius: 2;
    border-width: 0.1;
    border-color: #2563eb;
    font-size: 2.5;
    font-weight: medium;
    text-align: center;
    cursor: pointer;
    margin-top: 1.5;
  }

  .btn-restart {
    background-color: #ef4444;
    border-color: #dc2626;
  }
</style>

<div class="panel-container">
  <!-- WELCOME SCREEN -->
  <div id="welcome-screen" class="screen">
    <div class="card-screen">
      <span class="heading">MR SPATIAL DEFENDER</span>
      <span class="sub-heading">Defiende tu habitacion! Un portal alienigena aparecera en el centro. Dispara con el gatillo de tu mando para destruir los drones antes de que te alcancen.</span>
      <button id="start-button" class="btn">Empezar Juego</button>
    </div>
  </div>

  <!-- HUD SCREEN (DIVIDIDO A LA IZQUIERDA Y DERECHA) -->
  <div id="hud-screen" class="hud-screen hidden">
    <div class="hud-split-container">
      <!-- Bloque Izquierdo: Puntos -->
      <div class="hud-card">
        <span id="score-text" class="hud-item">PUNTOS: 0</span>
      </div>
      
      <!-- Bloque Derecho: Vida -->
      <div class="hud-card">
        <span id="life-text" class="hud-item" style="color: #10b981;">VIDA: 100%</span>
      </div>
    </div>
  </div>

  <!-- GAME OVER SCREEN -->
  <div id="game-over-screen" class="screen hidden">
    <div class="card-screen">
      <span class="heading" style="color: #ef4444;">FIN DE PARTIDA</span>
      <span id="final-score-text" class="sub-heading">Puntuacion final: 0</span>
      <button id="restart-button" class="btn btn-restart">Jugar de Nuevo</button>
    </div>
  </div>
</div>
